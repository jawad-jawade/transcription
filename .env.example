# Telegram Bot Token (van @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter API Key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Resend API Key (https://resend.com/api-keys)
RESEND_API_KEY=your_resend_api_key_here

# E-mail afzender (moet geverifieerd zijn in Resend)
FROM_EMAIL=samenvatting@example.com
FROM_NAME=Gesprek Samenvatting

# Telegram User IDs die de bot mogen gebruiken (komma-gescheiden, laat leeg voor iedereen)
# Stuur /mijnid naar de bot om jouw user ID te vinden
ALLOWED_USER_IDS=your_telegram_user_id_here

# OpenRouter model voor samenvatting
SUMMARY_MODEL=anthropic/claude-sonnet-4

# OpenRouter model voor transcriptie (multimodal met audio support)
TRANSCRIPTION_MODEL=openai/gpt-4o-audio-preview
