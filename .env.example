# Telegram Bot Token (van @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter API Key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Resend API Key (https://resend.com/api-keys)
RESEND_API_KEY=your_resend_api_key_here

# E-mail afzender (moet geverifieerd zijn in Resend)
FROM_EMAIL=samenvatting@example.com
FROM_NAME=Gesprek Samenvatting

# Telegram User IDs die de bot mogen gebruiken (komma-gescheiden, laat leeg voor iedereen)
# Stuur /mijnid naar de bot om jouw user ID te vinden
ALLOWED_USER_IDS=your_telegram_user_id_here

# OpenRouter model voor samenvatting (goedkoop, geen gedeelde rate-limits zoals gratis modellen)
SUMMARY_MODEL=openai/gpt-4o-mini

# OpenRouter model voor transcriptie (betaald, betrouwbare audio-ondersteuning)
TRANSCRIPTION_MODEL=openai/gpt-audio-mini

# Optioneel: zelf-gehoste Telegram Bot API server (https://github.com/tdlib/telegram-bot-api)
# Laat leeg om de standaard cloud-API te gebruiken (limiet: 20MB per bestand).
# Met een lokale server kunnen bestanden tot 2GB verwerkt worden.
# TELEGRAM_LOCAL_API_URL=http://127.0.0.1:8081
# TELEGRAM_LOCAL_API_CONTAINER_DIR=/var/lib/telegram-bot-api
# TELEGRAM_LOCAL_API_HOST_DIR=/opt/telegram-bot-api-data
